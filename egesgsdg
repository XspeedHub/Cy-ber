local yogaBorders = {}

local function mkYogaBorder(parent, thickBase, thickPeak, speed)
    speed = speed or 160; thickBase = thickBase or 1.5; thickPeak = thickPeak or 2.8
    local s = Instance.new("UIStroke", parent)
    s.Color = Color3.fromRGB(0, 40, 120); s.Thickness = thickBase; s.Transparency = 0.2
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(0, 20, 80)),
        ColorSequenceKeypoint.new(0.4, Color3.fromRGB(0, 100, 220)),
        ColorSequenceKeypoint.new(0.6, Color3.fromRGB(0, 100, 220)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(0, 20, 80)),
    })
    g.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0,    0.85),
        NumberSequenceKeypoint.new(0.45, 0.05),
        NumberSequenceKeypoint.new(0.55, 0.05),
        NumberSequenceKeypoint.new(1,    0.85),
    })
    g.Parent = s
    TweenService:Create(s, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
        Thickness = thickPeak, Transparency = 0.0,
    }):Play()
    table.insert(yogaBorders, {g = g, speed = speed})
    return s
end

