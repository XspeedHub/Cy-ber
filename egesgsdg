-- HUD FPS/Ping updater (FIXED - triple fallback ping)
-- ============================================================
do
    local _fc=0; local _lt=tick()
    RunService.RenderStepped:Connect(function()
        _fc += 1
        local now = tick()
        if now - _lt >= 1 then
            hudFpsVal.Text = tostring(math.floor(_fc/(now-_lt)))
            _fc=0; _lt=now
        end

        -- Fallback 1: "Data Ping" (with space) — correct key in most Roblox versions
        local ping = 0
        pcall(function()
            ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        end)
        -- Fallback 2: "DataPing" (no space) — older executor compatibility
        if ping == 0 then
            pcall(function()
                ping = math.floor(Stats.Network.ServerStatsItem["DataPing"]:GetValue())
            end)
        end
        -- Fallback 3: GetNetworkPing() — most reliable modern method (returns seconds -> *1000 for ms)
        if ping == 0 then
            pcall(function()
                ping = math.floor(Players.LocalPlayer:GetNetworkPing() * 1000)
            end)
        end

        hudPingVal.Text = tostring(ping).."ms"
    end)
end

