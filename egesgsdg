local VYSE_AIMBOT_SPEED = 60
local VYSE_HIT_DIST     = 2.3
local SWING_COOLDOWN    = 0.08

local function findAnyTool()
    local c = LP.Character
    if c then for _, v in ipairs(c:GetChildren()) do if v:IsA("Tool") then return v end end end
    local bp = LP:FindFirstChildOfClass("Backpack")
    if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") then return v end end end
    return nil
end

local function getClosestPlayer()
    local char = LP.Character; if not char then return nil, math.huge end
    local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return nil, math.huge end
    local cp, cd = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local tr = p.Character:FindFirstChild("HumanoidRootPart")
            local ph = p.Character:FindFirstChildOfClass("Humanoid")
            if tr and ph and ph.Health > 0 then
                local d = (hrp.Position - tr.Position).Magnitude
                if d < cd then cd = d; cp = p end
            end
        end
    end
    return cp, cd
end

local function tryHitBat()
    if State.hittingCooldown then return end; State.hittingCooldown = true
    pcall(function()
        local c = LP.Character; if not c then return end
        local hum2 = c:FindFirstChildOfClass("Humanoid")
        local tool = findAnyTool()
        if tool then
            if tool.Parent ~= c and hum2 then pcall(function() hum2:EquipTool(tool) end) end
            local remote = tool:FindFirstChildOfClass("RemoteEvent")
            if remote then pcall(function() remote:FireServer() end)
            else pcall(function() tool:Activate() end) end
        end
    end)
    task.delay(SWING_COOLDOWN, function() State.hittingCooldown = false end)
end

local function activateAntiDie()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    hum.BreakJointsOnDeath = false
    hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    hum:GetPropertyChangedSignal("Health"):Connect(function()
        if hum.Health <= 0 then hum.Health = hum.MaxHealth end
    end)
    hum.Died:Connect(function()
        task.wait()
        local newHum = Instance.new("Humanoid")
        newHum.Name = "ReplacedHumanoid"
        newHum.Parent = char
        workspace.CurrentCamera.CameraSubject = newHum
        hum:Destroy()
    end)
end

startBatAimbot = function()
    if Conns.aimbot then return end
    local char0 = LP.Character
    local hum0 = char0 and char0:FindFirstChildOfClass("Humanoid")
    if hum0 then hum0.AutoRotate = false end
    local initTarget, _ = getClosestPlayer()
    if initTarget and initTarget.Character then
        local root0 = char0 and char0:FindFirstChild("HumanoidRootPart")
        local tr0 = initTarget.Character:FindFirstChild("HumanoidRootPart")
        if root0 and tr0 then
            local look = Vector3.new(tr0.Position.X, root0.Position.Y, tr0.Position.Z)
            root0.CFrame = CFrame.new(root0.Position, look)
        end
    end
    local _lastTargetY = nil
    local _tpCooldown = false
    Conns.aimbot = RunService.Heartbeat:Connect(function()
        if not State.batAimbotToggled then return end
        local c = LP.Character; if not c then return end
        local root = c:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum2 = c:FindFirstChildOfClass("Humanoid"); if not hum2 then return end
        local target, dist = getClosestPlayer()
        if target and target.Character then
            local tr = target.Character:FindFirstChild("HumanoidRootPart")
            if tr then
                local tVel = tr.AssemblyLinearVelocity
                local tHorVel = Vector3.new(tVel.X, 0, tVel.Z)
                local isMoving = tHorVel.Magnitude > 1
                local curY = tr.Position.Y
                if _lastTargetY then
                    local yDrop = _lastTargetY - curY
                    if yDrop >= 5 and not _tpCooldown then
                        _tpCooldown = true
                        pcall(function()
                            local rp = RaycastParams.new()
                            rp.FilterDescendantsInstances = {c}
                            rp.FilterType = Enum.RaycastFilterType.Exclude
                            local res = workspace:Raycast(root.Position, Vector3.new(0, -1000, 0), rp)
                            if res then
                                root.CFrame = CFrame.new(res.Position + Vector3.new(0, root.Size.Y/2 + 0.5, 0))
                                root.AssemblyLinearVelocity = Vector3.zero
                            end
                        end)
                        task.delay(0.3, function() _tpCooldown = false end)
                    end
                end
                _lastTargetY = curY
                local standPos, facePos
                if isMoving then
                    local moveDir = tHorVel.Unit
                    standPos = tr.Position + moveDir * 3
                    facePos = root.Position + moveDir
                else
                    local behindDir = -Vector3.new(tr.CFrame.LookVector.X, 0, tr.CFrame.LookVector.Z).Unit
                    standPos = tr.Position + behindDir * 2.5
                    facePos = Vector3.new(tr.Position.X, root.Position.Y, tr.Position.Z)
                end
                local toStand = standPos - root.Position
                local toStandH = Vector3.new(toStand.X, 0, toStand.Z)
                local yDiff = standPos.Y - root.Position.Y
                if toStandH.Magnitude > 0.5 then
                    local yVel = math.clamp(yDiff * 6, -VYSE_AIMBOT_SPEED, VYSE_AIMBOT_SPEED)
                    hum2:Move(toStandH.Unit, false)
                    root.AssemblyLinearVelocity = Vector3.new(toStandH.Unit.X * VYSE_AIMBOT_SPEED, yVel, toStandH.Unit.Z * VYSE_AIMBOT_SPEED)
                else
                    local yVel = math.clamp(yDiff * 6, -VYSE_AIMBOT_SPEED, VYSE_AIMBOT_SPEED)
                    hum2:Move(Vector3.zero, false)
                    root.AssemblyLinearVelocity = Vector3.new(tVel.X, yVel, tVel.Z)
                end
                if (facePos - root.Position).Magnitude > 0.1 then
                    root.CFrame = CFrame.new(root.Position, Vector3.new(facePos.X, root.Position.Y, facePos.Z))
                    -- Re-apply velocity immediately after CFrame snap
                    if toStandH.Magnitude > 0.5 then
                        local yVel = math.clamp(yDiff * 6, -VYSE_AIMBOT_SPEED, VYSE_AIMBOT_SPEED)
                        root.AssemblyLinearVelocity = Vector3.new(toStandH.Unit.X * VYSE_AIMBOT_SPEED, yVel, toStandH.Unit.Z * VYSE_AIMBOT_SPEED)
                    end
                end
                if dist <= VYSE_HIT_DIST then tryHitBat() end
            end
        else
            _lastTargetY = nil
            hum2:Move(Vector3.zero, false)
            root.AssemblyLinearVelocity = Vector3.zero
        end
    end)
end

stopBatAimbot = function()
    if Conns.aimbot then Conns.aimbot:Disconnect(); Conns.aimbot = nil end
    local c = LP.Character
