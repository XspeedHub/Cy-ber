        if isRagdolled then
            State.batCounterDebounce=true
            task.spawn(function()
                local bat=findBatForCounter()
                if bat then swingBatForCounter(bat,char) end
                task.wait(0.1)
                State.batCounterDebounce=false
            end)
        end
    end)
end

