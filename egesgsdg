local function findMedusa()
    local c=LP.Character; if not c then return nil end
    for _,t in ipairs(c:GetChildren()) do if t:IsA("Tool") then local n=t.Name:lower(); if n:find("medusa") or n:find("head") or n:find("stone") then return t end end end
    local bp=LP:FindFirstChild("Backpack")
    if bp then for _,t in ipairs(bp:GetChildren()) do if t:IsA("Tool") then local n=t.Name:lower(); if n:find("medusa") or n:find("head") or n:find("stone") then return t end end end end
    return nil
end
local function useMedusaCounter()
    if State.medusaDebounce then return end
    if tick()-State.medusaLastUsed<MEDUSA_COOLDOWN then return end
    local c=LP.Character; if not c then return end
    State.medusaDebounce=true
    local hum2=c:FindFirstChildOfClass("Humanoid")
    for _,t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower():find("bat") then
            if hum2 then pcall(function() hum2:UnequipTools() end) end
            break
        end
    end
    local med=findMedusa(); if not med then State.medusaDebounce=false; return end
    if med.Parent~=c then
        task.spawn(function() if hum2 then pcall(function() hum2:EquipTool(med) end) end end)
    end
    for _=1,6 do pcall(function() med:Activate() end) end
    task.spawn(function()
        for _=1,6 do task.wait(); pcall(function() med:Activate() end) end
    end)
    State.medusaLastUsed=tick()
    task.delay(0.03, function() State.medusaDebounce=false end)
end
