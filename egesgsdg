    btnFrame.MouseEnter:Connect(function()
        if not btnState then
            TweenService:Create(btnFrame, TweenInfo.new(0.1), {BackgroundColor3 = THEME.LIGHT_BLUE}):Play()
        end
    end)
    
    btnFrame.MouseLeave:Connect(function()
        if not btnState then
            TweenService:Create(btnFrame, TweenInfo.new(0.1), {BackgroundColor3 = btnState and C.stackActBg or C.stackBg}):Play()
        end
    end)
    
    local function onTap()
        if def.key == "tpDown" then 
            doTpDown() 
            return 
        end
        
        if def.key == "carrySpeed" then 
            local ns = not btnState
            if ns and State.laggerEnabled then
                State.laggerEnabled = false
                if stackBtnRefs.lagger then 
                    stackBtnRefs.lagger.setOn(false) 
                end
                State.carrySpeed = State._prevCarry or 30
                State.speedToggled = State._prevSpeed or false
                if carryBox then carryBox.Text = tostring(State.carrySpeed) end
            end
            State.speedToggled = ns
            setOn(State.speedToggled)
            if ns then
                State._prevCarry = State.carrySpeed
                State._prevSpeed = true
                if carryBox then carryBox.Text = tostring(State.carrySpeed) end
            else
                State.carrySpeed = State._prevCarry or 30
                if carryBox then carryBox.Text = tostring(State.carrySpeed) end
            end
            return
        end
        
        if def.key == "lagger" then
            local ns = not btnState
            if ns and State.speedToggled then
                State.speedToggled = false
                if stackBtnRefs.carrySpeed then 
                    stackBtnRefs.carrySpeed.setOn(false) 
                end
                State._prevCarry = State.carrySpeed
                State._prevSpeed = false
            end
            State.laggerEnabled = ns
            setOn(State.laggerEnabled)
            if ns then
                if carryBox then carryBox.Text = tostring(State.laggerSpeed) end
            else
                State.carrySpeed = State._prevCarry or 30
                State.speedToggled = State._prevSpeed or false
                if carryBox then carryBox.Text = tostring(State.carrySpeed) end
                if stackBtnRefs.carrySpeed then 
                    stackBtnRefs.carrySpeed.setOn(State.speedToggled) 
                end
            end
            return
        end
        
        if def.key == "drop" then
            runDropBrainrot()
            return
        end
        
        if def.key == "aimbot" then
            if not aimbotActive then
                if State.autoLeftEnabled then
                    State.autoLeftEnabled = false
                    if stackBtnRefs.autoLeft then stackBtnRefs.autoLeft.setOn(false) end
                    stopAutoLeft()
                end
                if State.autoRightEnabled then
                    State.autoRightEnabled = false
                    if stackBtnRefs.autoRight then stackBtnRefs.autoRight.setOn(false) end
                    stopAutoRight()
                end
            end
            toggleAimbot()
            return
        end
        
        if def.key == "autoLeft" then
            local ns = not btnState
            if ns and State.autoRightEnabled then
                State.autoRightEnabled = false
                if stackBtnRefs.autoRight then stackBtnRefs.autoRight.setOn(false) end
                stopAutoRight()
            end
            State.autoLeftEnabled = ns
            setOn(State.autoLeftEnabled)
            if ns and aimbotActive then toggleAimbot() end
            if ns then 
                startAutoLeft() 
            else 
                stopAutoLeft() 
            end
            return
        end
        
        if def.key == "autoRight" then
            local ns = not btnState
            if ns and State.autoLeftEnabled then
                State.autoLeftEnabled = false
                if stackBtnRefs.autoLeft then stackBtnRefs.autoLeft.setOn(false) end
                stopAutoLeft()
            end
            State.autoRightEnabled = ns
            setOn(State.autoRightEnabled)
            if ns and aimbotActive then toggleAimbot() end
            if ns then 
                startAutoRight() 
            else 
                stopAutoRight() 
            end
            return
        end
    end
    
    makeStackDraggable(btnFrame, onTap)
end

