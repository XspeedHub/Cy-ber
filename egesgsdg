local function doStartUnwalk()
    local c = LP.Character; if not c then return end
    local hum2     = c:FindFirstChildOfClass("Humanoid")
    local animCtrl = c:FindFirstChildOfClass("AnimationController")
    local anim     = c:FindFirstChild("Animate")
    if anim and anim:IsA("LocalScript") then
        anim.Disabled   = true
        unwalkAnimateRef = anim
    end
    local function stopAllTracks()
        if hum2 then for _, t in ipairs(hum2:GetPlayingAnimationTracks()) do pcall(function() t:Stop(0) end) end end
        if animCtrl then for _, t in ipairs(animCtrl:GetPlayingAnimationTracks()) do pcall(function() t:Stop(0) end) end end
    end
    stopAllTracks()
    if Conns.unwalk then Conns.unwalk:Disconnect(); Conns.unwalk = nil end
    Conns.unwalk = RunService.Heartbeat:Connect(function()
        if not State.unwalkEnabled then return end
        local c2    = LP.Character; if not c2 then return end
        local h2    = c2:FindFirstChildOfClass("Humanoid")
        local ac2   = c2:FindFirstChildOfClass("AnimationController")
        local root2 = c2:FindFirstChild("HumanoidRootPart")
        if h2 then for _, t in ipairs(h2:GetPlayingAnimationTracks()) do pcall(function() t:Stop(0) end) end end
        if ac2 then for _, t in ipairs(ac2:GetPlayingAnimationTracks()) do pcall(function() t:Stop(0) end) end end
        if root2 and h2 then
            if h2.MoveDirection.Magnitude == 0 then
                root2.AssemblyAngularVelocity = Vector3.zero
                root2.AssemblyLinearVelocity  = Vector3.new(0, root2.AssemblyLinearVelocity.Y, 0)
            end
        end
    end)
end

local function doStopUnwalk()
    if Conns.unwalk then Conns.unwalk:Disconnect(); Conns.unwalk = nil end
    local c = LP.Character
    if c and unwalkAnimateRef and unwalkAnimateRef.Parent == c then
        unwalkAnimateRef.Disabled = false
        task.delay(0.05, function()
            if unwalkAnimateRef and unwalkAnimateRef.Parent then
                unwalkAnimateRef.Disabled = true
                task.wait(0.05)
