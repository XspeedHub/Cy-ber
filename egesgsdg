-- FPS/Ping updater
do
    local _fc = 0; local _lt = tick()
    RunService.RenderStepped:Connect(function()
        _fc += 1
        local now = tick()
        if now - _lt >= 1 then
            hudFpsVal.Text = tostring(math.floor(_fc / (now - _lt)))
            _fc = 0; _lt = now
        end
        local ping = 0
        pcall(function() ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
        if ping == 0 then pcall(function() ping = math.floor(Stats.Network.ServerStatsItem["DataPing"]:GetValue()) end) end
        if ping == 0 then pcall(function() ping = math.floor(LP:GetNetworkPing() * 1000) end) end
        hudPingVal.Text = tostring(ping) .. "ms"
        
        if ping < 50 then
            hudPingVal.TextColor3 = Color3.fromRGB(0, 255, 100)
        elseif ping < 120 then
            hudPingVal.TextColor3 = Color3.fromRGB(255, 200, 0)
        else
            hudPingVal.TextColor3 = Color3.fromRGB(255, 50, 50)
        end
    end)
end

