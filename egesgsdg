    lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left

    -- track — full capsule (solar hub style)
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0,TRACK_W,0,TRACK_H)
    track.Position = UDim2.new(1,-(TRACK_W+10),0.5,-TRACK_H/2)
    track.BackgroundColor3 = Color3.fromRGB(75,70,130)
    track.BorderSizePixel = 0; track.ZIndex = 7; track.ClipsDescendants = false
    mkCorner(track, TRACK_H/2)
    mkYogaBorder(track, 1.0, 2.0, 160)

    -- rotating gradient on track (spins when ON, plain when OFF — solar style)
    local trackGrad = Instance.new("UIGradient", track)
    -- off state: flat purple-grey, no rotation
    local GREEN_KEYS_SEQ = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(0,40,140)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(0,100,255)),
    })
    local OFF_SEQ = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(75,70,130)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(75,70,130)),
    })
    trackGrad.Color = defaultOn and GREEN_KEYS_SEQ or OFF_SEQ

    -- knob — white circle
    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,KNOB_S,0,KNOB_S)
    knob.Position = defaultOn and UDim2.new(0,KNOB_ON_X,0.5,-KNOB_S/2) or UDim2.new(0,KNOB_OFF_X,0.5,-KNOB_S/2)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0; knob.ZIndex = 9
    mkCorner(knob, KNOB_S/2)

    local isOn = defaultOn or false
    -- seed the spinner if default is on
    if isOn then table.insert(toggleTrackGradients, trackGrad) end

    local function setV(on)
        isOn = on
        local ti = TweenInfo.new(0.15, Enum.EasingStyle.Quad)
        -- knob slides
        TweenService:Create(knob, ti, {
            Position = on and UDim2.new(0,KNOB_ON_X,0.5,-KNOB_S/2) or UDim2.new(0,KNOB_OFF_X,0.5,-KNOB_S/2),
            BackgroundColor3 = Color3.fromRGB(255,255,255),
        }):Play()
        -- track colour: spinning green or flat purple-grey
        if on then
            trackGrad.Color = GREEN_KEYS_SEQ
            -- add to spinner if not already there
            local found = false
            for _, g in ipairs(toggleTrackGradients) do if g == trackGrad then found=true; break end end
            if not found then table.insert(toggleTrackGradients, trackGrad) end
        else
            trackGrad.Color = OFF_SEQ
            -- remove from spinner
            for idx, g in ipairs(toggleTrackGradients) do
                if g == trackGrad then table.remove(toggleTrackGradients, idx); break end
            end
        end
    end

    local function toggle() isOn=not isOn; setV(isOn); if onToggle then pcall(onToggle,isOn) end end
    local clk = Instance.new("TextButton", row)
    clk.Size = UDim2.new(1,-(TRACK_W+20),1,0); clk.BackgroundTransparency = 1; clk.Text = ""
    clk.ZIndex = 5; clk.BorderSizePixel = 0; clk.MouseButton1Click:Connect(toggle)
    local tClk = Instance.new("TextButton", track)
    tClk.Size = UDim2.new(1,0,1,0); tClk.BackgroundTransparency = 1; tClk.Text = ""
    tClk.ZIndex = 10; tClk.BorderSizePixel = 0; tClk.MouseButton1Click:Connect(toggle)
    return setV
end

