local function setupPlayerResetDetection()
    if Conns.playerRespawn then return end
    Conns.playerRespawn = Players.PlayerAdded:Connect(function(player)
        if player == LP then return end
        player.CharacterAdded:Connect(function(character)
            if State.batAimbotToggled and aimbotLockedTarget and aimbotLockedTarget == character then
                aimbotLockedTarget = nil; aimbotNoTargetSince = nil
            end
            if aimbotLockedTarget and not aimbotLockedTarget.Parent then
                aimbotLockedTarget = nil; aimbotNoTargetSince = nil
            end
        end)
        player.CharacterRemoving:Connect(function(character)
            if State.batAimbotToggled and aimbotLockedTarget == character then
                aimbotLockedTarget = nil; aimbotNoTargetSince = nil
            end
        end)
    end)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LP then
            player.CharacterAdded:Connect(function(character)
                if State.batAimbotToggled and aimbotLockedTarget == character then
                    aimbotLockedTarget = nil; aimbotNoTargetSince = nil
                end
            end)
            player.CharacterRemoving:Connect(function(character)
                if State.batAimbotToggled and aimbotLockedTarget == character then
                    aimbotLockedTarget = nil; aimbotNoTargetSince = nil
                end
            end)
        end
    end
end

local function _aimbotTargetValid(tc)
    if not tc or not tc.Parent then return false end
    local hum2 = tc:FindFirstChildOfClass("Humanoid")
    local hrp2 = tc:FindFirstChild("HumanoidRootPart")
    if hum2 then
        if hum2.Health <= 0 then return false end
        local state = hum2:GetState()
        if state == Enum.HumanoidStateType.Dead then return false end
    end
    return hum2 and hrp2 and not tc:FindFirstChildOfClass("ForceField")
end

local function _aimbotGetTarget(myHRP)
    if aimbotLockedTarget and _aimbotTargetValid(aimbotLockedTarget) then
        local hrp2 = aimbotLockedTarget:FindFirstChild("HumanoidRootPart")
        if hrp2 and hrp2.Parent then return hrp2, aimbotLockedTarget end
    end
    local best, bestHRP, bestDist = nil, nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            local char = p.Character
            if _aimbotTargetValid(char) then
                local tHRP = char:FindFirstChild("HumanoidRootPart")
                if tHRP and tHRP.Parent then
                    local d = (tHRP.Position - myHRP.Position).Magnitude
                    if d < bestDist then bestDist=d; bestHRP=tHRP; best=char end
                end
            end
        end
    end
    aimbotLockedTarget = best
    return bestHRP, best
end

startBatAimbot = function()
    if Conns.aimbot then return end
    setupPlayerResetDetection()
    local c = LP.Character; if not c then return end
    local myHum = c:FindFirstChildOfClass("Humanoid"); if not myHum then return end
    pcall(function()
        myHum.BreakJointsOnDeath = false
        myHum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        myHum:GetPropertyChangedSignal("Health"):Connect(function()
            if State.batAimbotToggled and myHum.Health <= 0 then myHum.Health = myHum.MaxHealth end
        end)
        myHum.Died:Connect(function()
            if not State.batAimbotToggled then return end
            task.wait()
            local newHum = Instance.new("Humanoid"); newHum.Name = "ReplacedHumanoid"; newHum.Parent = c
            workspace.CurrentCamera.CameraSubject = newHum; myHum:Destroy()
        end)
    end)
    Conns.aimbot = RunService.Heartbeat:Connect(function()
        if not State.batAimbotToggled then return end
        local char = LP.Character; if not char or not char.Parent then return end
        local myHRP = char:FindFirstChild("HumanoidRootPart"); if not myHRP then return end
        local myH = char:FindFirstChildOfClass("Humanoid"); if not myH or myH.Health <= 0 then return end
        myH.AutoRotate = false

        local tHRP, tChar = _aimbotGetTarget(myHRP)
        if tHRP and tChar and tHRP.Parent and tChar.Parent then
            aimbotNoTargetSince = nil
            aimbotHighlight.Adornee = tChar
            myH:Move(Vector3.new(0,0,0), false)

            local tVel = tHRP.AssemblyLinearVelocity
            local predictTime = math.clamp(tVel.Magnitude / 150, 0.05, 0.2)
            local predicted = tHRP.Position + tVel * predictTime
            local dir = predicted - myHRP.Position
            local dist = dir.Magnitude

            local standPos = dist > 0 and (predicted - dir.Unit * 2.3) or predicted
            local moveDir = standPos - myHRP.Position

            local lookTarget = Vector3.new(predicted.X, myHRP.Position.Y, predicted.Z)
            if (lookTarget - myHRP.Position).Magnitude > 0.1 then
                myHRP.CFrame = CFrame.new(myHRP.Position, lookTarget)
            end

            if moveDir.Magnitude > 1 then
                myHRP.AssemblyLinearVelocity = moveDir.Unit * 60
            else
                myHRP.AssemblyLinearVelocity = tVel
            end
        else
            if not aimbotNoTargetSince then aimbotNoTargetSince = tick() end
            if tick() - aimbotNoTargetSince > 1.5 then
                aimbotLockedTarget = nil
                if myHRP and myHRP.Parent then myHRP.AssemblyLinearVelocity = Vector3.new(0,0,0) end
                aimbotHighlight.Adornee = nil
            end
        end
    end)
end

stopBatAimbot = function()
    if Conns.aimbot then Conns.aimbot:Disconnect(); Conns.aimbot = nil end
    aimbotLockedTarget = nil; aimbotNoTargetSince = nil; aimbotHighlight.Adornee = nil
    local c = LP.Character
    local myH = c and c:FindFirstChildOfClass("Humanoid")
    if myH then myH.AutoRotate = true; myH:Move(Vector3.new(0,0,0), false) end
    local root = c and c:FindFirstChild("HumanoidRootPart")
    if root then root.AssemblyLinearVelocity = Vector3.zero end
    State.hittingCooldown = false
end

