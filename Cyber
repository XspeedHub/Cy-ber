-- Normal Speed functions
local function applyNormalSpeed(character)
    if not NormalSpeed.Enabled then return end
    local hum = character and character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = NormalSpeed.WalkSpeed
    end
end

local function setupNormalSpeed()
    if NormalSpeed.connection then NormalSpeed.connection:Disconnect() end
    NormalSpeed.connection = lp.CharacterAdded:Connect(function(character)
        task.wait(0.2)
        applyNormalSpeed(character)
    end)
    if lp.Character then applyNormalSpeed(lp.Character) end
end

local function enableNormalSpeed()
    if NormalSpeed.Enabled then return end
    NormalSpeed.Enabled = true
    setupNormalSpeed()
end

local function disableNormalSpeed()
    if not NormalSpeed.Enabled then return end
    NormalSpeed.Enabled = false
    if lp.Character then
        local hum = lp.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = 16 end  -- default speed
    end
end

