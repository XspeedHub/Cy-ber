-- ============================================================
-- ANTI LAG
-- ============================================================
-- Wrap anti-lag locals in do..end so their registers are freed before the
-- sync/steal section below (PC Lua compiler has a hard 200-local limit per chunk).
do
    local antiLagConn = nil
    local antiLagConnections = {}

    local function applyAntiLag(instance)
        pcall(function()
            if instance:IsA("ParticleEmitter") then
                instance.Enabled = false
            elseif instance:IsA("Decal") or instance:IsA("Texture") then
                instance.Transparency = 1
            elseif instance:IsA("BasePart") then
                instance.CastShadow = false
                instance.Reflectance = 0
                if instance.Material ~= Enum.Material.Plastic then
                    instance.Material = Enum.Material.Plastic
                end
            elseif instance:IsA("MeshPart") then
                instance.CastShadow = false
                instance.RenderFidelity = Enum.RenderFidelity.Performance
            elseif instance:IsA("Model") then
                instance.LevelOfDetail = Enum.ModelLevelOfDetail.Disabled
            elseif instance:IsA("Fire") or instance:IsA("Smoke") or instance:IsA("Sparkles")
                or instance:IsA("Trail") or instance:IsA("Beam") then
                instance.Enabled = false
            elseif instance:IsA("SpotLight") or instance:IsA("PointLight") or instance:IsA("SurfaceLight") then
                instance.Enabled = false
            elseif instance:IsA("Accessory") then
                instance:Destroy()
            end
        end)
    end

    local function optimizeLighting()
        pcall(function()
            local Lighting = game:GetService("Lighting")
            Lighting.GlobalShadows = false
            Lighting.FogEnd = 9e9
            for _, child in pairs(Lighting:GetDescendants()) do
                if child:IsA("BloomEffect") or child:IsA("BlurEffect") or child:IsA("SunRaysEffect")
                or child:IsA("DepthOfFieldEffect") or child:IsA("ColorCorrectionEffect") then
                    child.Enabled = false
                end
            end
            local terrain = workspace:FindFirstChildOfClass("Terrain")
            if terrain then
                terrain.WaterReflectance = 0
                terrain.WaterWaveSize = 0
                terrain.WaterWaveSpeed = 0
            end
        end)
    end

    local function enableAntiLag()
        pcall(function() setfpscap(999999999) end)
        if antiLagConn then
            antiLagConn:Disconnect()
            antiLagConn = nil
        end
        for _, conn in ipairs(antiLagConnections) do
            pcall(function() conn:Disconnect() end)
        end
        antiLagConnections = {}
        optimizeLighting()
        for _, v in pairs(workspace:GetDescendants()) do
            applyAntiLag(v)
        end
        antiLagConn = workspace.DescendantAdded:Connect(function(desc)
            if State.antiLagEnabled then
                task.spawn(applyAntiLag, desc)
            end
        end)
        table.insert(antiLagConnections, antiLagConn)
    end

    local function disableAntiLag()
        pcall(function() setfpscap(60) end)
        if antiLagConn then
            antiLagConn:Disconnect()
            antiLagConn = nil
        end
        for _, conn in ipairs(antiLagConnections) do
            pcall(function() conn:Disconnect() end)
        end
        antiLagConnections = {}
    end

    -- Reassign the forward-declared outer locals (setFps, applyFPSBoost) so
    -- their closures capture enableAntiLag/disableAntiLag from this scope.
    local originalSetFps = setFps
    setFps = function(on)
        State.fpsBoostEnabled = on
        State.antiLagEnabled = on
        if on then
            pcall(enableAntiLag)
        else
            pcall(disableAntiLag)
        end
        if originalSetFps then pcall(originalSetFps, on) end
        pcall(saveConfig)
    end

    applyFPSBoost = function()
        pcall(enableAntiLag)
    end

    task.spawn(function()
        if State.fpsBoostEnabled then
            task.wait(1)
            pcall(enableAntiLag)
        end
    end)
end -- end anti-lag do block

