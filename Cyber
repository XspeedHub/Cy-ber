        if inputState == Enum.UserInputState.Begin then
            if actionName == "TpDown" and TpDown then
                tpDownAction()
            elseif actionName == "AutoLeft" then
                if AutoRight.Enabled then
                    AutoRight.Enabled = false
                    if AutoRight.btn then AutoRight.btn.Text = "Auto Right: OFF" end
