                        end
                    end
                    local statusLabel = nil
                    for _, child in ipairs(row:GetChildren()) do
                        if child:IsA("TextLabel") and child ~= label then statusLabel = child break end
                    end
                    if statusLabel then statusLabel.Text = "OFF" end
                end
            end
        end
    end
    saveConfig()
    -- Reapply normal speed
    if NormalSpeed.Enabled then enableNormalSpeed() else disableNormalSpeed() end
end

