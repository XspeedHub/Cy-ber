    OptimizerEnabled = false
end

-- ========== AUTO MEDUSA FUNCTIONS (IMPROVED - with auto-equip and counter) ==========
local function initAutoMedusa()
    if AutoMedusa.initialized then return end
    AutoMedusa.initialized = true

    local function createRadius()
        if AutoMedusa.medusaPart then AutoMedusa.medusaPart:Destroy() end
        AutoMedusa.medusaPart = Instance.new("Part")
        AutoMedusa.medusaPart.Name = "MedusaRadius"
        AutoMedusa.medusaPart.Anchored = true
        AutoMedusa.medusaPart.CanCollide = false
        AutoMedusa.medusaPart.Transparency = 1
        AutoMedusa.medusaPart.Material = Enum.Material.Neon
        AutoMedusa.medusaPart.Color = Color3.fromRGB(255, 0, 0)
        AutoMedusa.medusaPart.Shape = Enum.PartType.Cylinder
        AutoMedusa.medusaPart.Size = Vector3.new(0.05, AutoMedusa.MEDUSA_RADIUS*2, AutoMedusa.MEDUSA_RADIUS*2)
        AutoMedusa.medusaPart.Parent = workspace
    end

    local function isMedusaEquipped()
        local char = lp.Character
        if not char then return nil end
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name == "Medusa's Head" or tool.Name:lower():find("medusa")) then
                return tool
            end
        end
        return nil
    end

    local function equipMedusa()
        local char = lp.Character
        if not char then return false end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return false end
        
        -- Check if already equipped
        if isMedusaEquipped() then return true end
        
        -- Find Medusa in backpack
        local bp = lp:FindFirstChild("Backpack")
        if bp then
            for _, tool in ipairs(bp:GetChildren()) do
                if tool:IsA("Tool") and (tool.Name == "Medusa's Head" or tool.Name:lower():find("medusa")) then
                    hum:EquipTool(tool)
                    task.wait(0.1)
                    return true
                end
            end
        end
        return false
    end

    local function useMedusa()
        if tick() - AutoMedusa.lastUse < AutoMedusa.SPAM_DELAY then return end
        local char = lp.Character
        if not char then return end
        
        -- Auto-equip Medusa if not equipped
        if not isMedusaEquipped() then
            equipMedusa()
            task.wait(0.05)
        end
        
        local tool = isMedusaEquipped()
        if tool then
            pcall(function() tool:Activate() end)
            AutoMedusa.lastUse = tick()
        end
    end

    -- Check if player is being Medusa'd (anchored/stoned)
    local function isBeingMedusad()
        local char = lp.Character
        if not char then return false end
        
        -- Check if player is anchored (petrified)
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Anchored then
            return true
        end
        
        -- Check for stone material or effects
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                if part.Material == Enum.Material.Slate or part.Material == Enum.Material.Concrete then
                    return true
                end
            end
        end
        
        return false
    end

    createRadius()

    -- Visual radius (red circle when enabled)
    RunService.RenderStepped:Connect(function()
        if not AutoMedusa.Enabled then
            if AutoMedusa.medusaPart then AutoMedusa.medusaPart.Transparency = 1 end
            return
        end
        if AutoMedusa.medusaPart then 
            AutoMedusa.medusaPart.Transparency = 0.75
            AutoMedusa.medusaPart.Color = Color3.fromRGB(255, 50, 50)
        end
        local char = lp.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        AutoMedusa.medusaPart.CFrame = CFrame.new(root.Position + Vector3.new(0, -2.5, 0)) * CFrame.Angles(0, 0, math.rad(90))
    end)

    -- Main Auto Medusa logic
    RunService.Heartbeat:Connect(function()
        if not AutoMedusa.Enabled then return end
        
        local char = lp.Character
        if not char then return end
        
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        -- CHECK IF BEING MEDUSA'D (COUNTER ATTACK)
        if isBeingMedusad() and tick() - AutoMedusa.lastMedusaHit > AutoMedusa.COUNTER_DELAY then
            AutoMedusa.lastMedusaHit = tick()
            -- Force use Medusa to counter
            useMedusa()
            return
        end
        
        -- Check for nearby enemies to petrify
        local tool = isMedusaEquipped()
        if not tool then
            equipMedusa()
            tool = isMedusaEquipped()
        end
        
        if not tool then return end
        if tick() - AutoMedusa.lastUse < AutoMedusa.SPAM_DELAY then return end
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= lp then
                local pChar = plr.Character
                local pRoot = pChar and pChar:FindFirstChild("HumanoidRootPart")
                if pRoot then
                    local distance = (pRoot.Position - root.Position).Magnitude
                    if distance <= AutoMedusa.MEDUSA_RADIUS then
                        tool:Activate()
                        AutoMedusa.lastUse = tick()
                        break
                    end
                end
            end
        end
    end)
end

local function enableAutoMedusa()
    if AutoMedusa.Enabled then return end
    AutoMedusa.Enabled = true
