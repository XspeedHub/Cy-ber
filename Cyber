local function updateStealProgress()
    if not StealTracker.isStealing then return end
    local startTime = tick()
    local duration = StealTracker.stealDuration   -- this is holdMax

    if StealTracker.statusLabel then
        StealTracker.statusLabel.Text = "HOLDING..."
        StealTracker.statusLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    end
    if StealTracker.progressBar then
        StealTracker.progressBar.Size = UDim2.new(0, 0, 1, 0)
    end
    if StealTracker.percentLabel then
        StealTracker.percentLabel.Text = "0%"
        StealTracker.percentLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    end

    if StealTracker.progressConn then
        StealTracker.progressConn:Disconnect()
    end

    StealTracker.progressConn = RunService.Heartbeat:Connect(function(dt)
        local elapsed  = tick() - startTime
        local progress = math.min(elapsed / duration, 1)
        local phase    = _StealState.phase
        local justDone = _StealState.lastResultTime > 0 and (tick()-_StealState.lastResultTime) < 1.4
        local success  = justDone and string.find(_StealState.lastResult, "Stole") ~= nil

        -- Fill color phases (semi-auto grab scheme):
        --   holding   → silver/white
        --   waitingRange → yellow (held fully, scanning for range)
        --   justDone  → green (success) or red (missed)
        local fillColor
        if justDone then
            fillColor = success and Color3.fromRGB(100, 255, 130) or Color3.fromRGB(255, 80, 80)
        elseif phase == "waitingRange" then
            fillColor = Color3.fromRGB(255, 220, 60)
        else
            fillColor = Color3.fromRGB(220, 220, 220)
        end

        if StealTracker.progressBar then
            -- Keep bar full once steal completes so result color is visible
            local displayProgress = (not StealTracker.isStealing or justDone) and 1 or progress
            StealTracker.progressBar.Size = UDim2.new(displayProgress, 0, 1, 0)
            StealTracker.progressBar.BackgroundColor3 =
                StealTracker.progressBar.BackgroundColor3:Lerp(fillColor, math.min((dt or 0.03)*10, 1))
        end

        if StealTracker.percentLabel then
            if not StealTracker.isStealing then
                StealTracker.percentLabel.Text = "100%"
            else
                StealTracker.percentLabel.Text = math.floor(progress*100) .. "%"
            end
        end

        if StealTracker.statusLabel then
            if justDone then
                StealTracker.statusLabel.Text = success and "STOLEN!" or "MISSED"
                StealTracker.statusLabel.TextColor3 = success
                    and Color3.fromRGB(100, 255, 130)
                    or  Color3.fromRGB(255, 80, 80)
            elseif phase == "holding" then
                StealTracker.statusLabel.Text = "HOLDING..."
                StealTracker.statusLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
            elseif phase == "waitingRange" then
                StealTracker.statusLabel.Text = "WAIT RANGE"
                StealTracker.statusLabel.TextColor3 = Color3.fromRGB(255, 220, 60)
            else
                StealTracker.statusLabel.Text = "NOT READY"
                StealTracker.statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
        end

        -- Once the result has been displayed for 1.4s, clean up the bar
        if not StealTracker.isStealing and not justDone then
            if StealTracker.progressConn then StealTracker.progressConn:Disconnect() end
            StealTracker.progressConn = nil
            if StealTracker.statusLabel then
                StealTracker.statusLabel.Text  = "NOT READY"
                StealTracker.statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
            if StealTracker.percentLabel then
                StealTracker.percentLabel.Text = "0%"
                StealTracker.percentLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
            if StealTracker.progressBar then
                StealTracker.progressBar.Size = UDim2.new(0, 0, 1, 0)
                StealTracker.progressBar.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
            end
        end
    end)
end

local function showStealProgress(duration)
    if not StealTracker.screenGui then
        createStealTrackerUI()
    end
    
    StealTracker.stealDuration = duration or 0.2
    StealTracker.isStealing = true
    
    updateStealProgress()
end

local function hideStealProgress()
    -- Signal that stealing is done; do NOT immediately wipe the bar.
    -- updateStealProgress keeps running for 1.4s so the green/red result
    -- color stays visible, then auto-resets once justDone expires.
    StealTracker.isStealing = false
end

-- ============================================================
-- MUTUAL EXCLUSIVITY FUNCTION
-- ============================================================
local function ensureMutualExclusive(activeKey)
    if activeKey == "autoLeft" and State.autoRightEnabled then
        State.autoRightEnabled = false
        if stackBtnRefs.autoRight then stackBtnRefs.autoRight.setOn(false) end
        stopAutoRight()
    elseif activeKey == "autoRight" and State.autoLeftEnabled then
        State.autoLeftEnabled = false
        if stackBtnRefs.autoLeft then stackBtnRefs.autoLeft.setOn(false) end
        stopAutoLeft()
    elseif activeKey == "carrySpeed" and State.laggerEnabled then
        State.laggerEnabled = false
        if stackBtnRefs.lagger then stackBtnRefs.lagger.setOn(false) end
        if carryBox then carryBox.Text = tostring(State.normalSpeed) end
    elseif activeKey == "lagger" and State.speedToggled then
        State.speedToggled = false
        if stackBtnRefs.carrySpeed then stackBtnRefs.carrySpeed.setOn(false) end
        if carryBox then carryBox.Text = tostring(State.normalSpeed) end
    end
end

