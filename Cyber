local function createAutoLeftUI()
    if AutoLeft.gui then return end
    AutoLeft.gui = Instance.new("ScreenGui")
    AutoLeft.gui.Name = "AutoLeftUI"
    AutoLeft.gui.ResetOnSpawn = false
    AutoLeft.gui.Enabled = true
    AutoLeft.gui.Parent = CoreGui
    AutoLeft.btn = Instance.new("TextButton")
    AutoLeft.btn.Size = UDim2.new(0,100,0,40)
    AutoLeft.btn.Position = UDim2.new(0.5,-50,0.45,0)
    AutoLeft.btn.Text = "Auto Left: OFF"
    AutoLeft.btn.Font = Enum.Font.GothamBold
    AutoLeft.btn.TextSize = 14
    AutoLeft.btn.TextColor3 = Color3.new(1,1,1)
    AutoLeft.btn.BackgroundColor3 = COLORS.Border
    AutoLeft.btn.AutoButtonColor = true
    AutoLeft.btn.Parent = AutoLeft.gui
    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(0,8)
    uiCorner.Parent = AutoLeft.btn
    if Config.Positions and Config.Positions.AutoLeftBtn then
        AutoLeft.btn.Position = UDim2.new(unpack(Config.Positions.AutoLeftBtn))
    end
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        AutoLeft.btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    AutoLeft.btn.InputBegan:Connect(function(input)
        if LockUIMove then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = AutoLeft.btn.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    AutoLeft.btn.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
    AutoLeft.btn.MouseButton1Click:Connect(function()
        if AutoRight.Enabled then
            AutoRight.Enabled = false
            if AutoRight.btn then AutoRight.btn.Text = "Auto Right: OFF" end
            stopAutoRight()
            ToggleStates["Auto Right"] = false
        end
        AutoLeft.Enabled = not AutoLeft.Enabled
        AutoLeft.btn.Text = AutoLeft.Enabled and "Auto Left: ON" or "Auto Left: OFF"
        ToggleStates["Auto Left"] = AutoLeft.Enabled
        if AutoLeft.Enabled then
            startAutoLeft()
        else
            stopAutoLeft()
        end
        saveConfig()
    end)
end

