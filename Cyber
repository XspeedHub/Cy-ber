local function doStartUnwalk()
    local c = LP.Character; if not c then return end
    local hum2 = c:FindFirstChildOfClass("Humanoid")
    if hum2 then
        for _, t in ipairs(hum2:GetPlayingAnimationTracks()) do t:Stop() end
    end
    local anim = c:FindFirstChild("Animate")
    if anim then
        unwalkAnimateRef = anim:Clone()
        anim:Destroy()
    end
end

local function doStopUnwalk()
    if Conns.unwalk then Conns.unwalk:Disconnect(); Conns.unwalk = nil end
    local c = LP.Character
    if c and unwalkAnimateRef then
        unwalkAnimateRef.Parent = c
        unwalkAnimateRef.Disabled = false
        unwalkAnimateRef = nil
    end
end

-- ============================================================
-- RAGDOLL TIMER WITH GRADIENT
-- ============================================================
local function startRagdollTimer()
    if ragTimerActive then return end
    ragTimerActive = true
    
    task.spawn(function()
        local char = LP.Character
        if not char then 
            ragTimerActive = false 
            return 
        end
        
        local head = char:FindFirstChild("Head")
        local bb = head and head:FindFirstChild("NyxoraHubBB")
        local timerLbl = bb and bb:FindFirstChild("RagdollTimerLbl")
        local speedLbl = bb and bb:FindFirstChild("SpeedBillLbl")
        
        -- Create timer label if it doesn't exist
        if not timerLbl and bb then
            timerLbl = Instance.new("TextLabel", bb)
            timerLbl.Name = "RagdollTimerLbl"
            timerLbl.Size = UDim2.new(1, 0, 0.5, 0)
            timerLbl.Position = UDim2.new(0, 0, 0.5, 0)
            timerLbl.BackgroundTransparency = 1
            timerLbl.Text = ""
            timerLbl.TextColor3 = THEME.LIGHT_BLUE
            timerLbl.FontFace = Font.new("rbxasset://fonts/families/Ubuntu.json", Enum.FontWeight.Bold, Enum.FontStyle.Italic)
            timerLbl.TextSize = 30
            timerLbl.TextXAlignment = Enum.TextXAlignment.Center
            timerLbl.TextYAlignment = Enum.TextYAlignment.Center
            timerLbl.TextStrokeTransparency = 0.1
            timerLbl.TextStrokeColor3 = Color3.new(0, 0, 0)
            timerLbl.ZIndex = 10
            timerLbl.Visible = false
            
            -- Create gradient for the timer label
            local timerGrad = Instance.new("UIGradient", timerLbl)
            timerGrad.Name = "TimerGradient"
            timerGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,    Color3.fromRGB(0, 255, 100)),
                ColorSequenceKeypoint.new(0.25, Color3.fromRGB(0, 200, 255)),
                ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(255, 255, 255)),
                ColorSequenceKeypoint.new(0.75, Color3.fromRGB(255, 200, 0)),
                ColorSequenceKeypoint.new(1,    Color3.fromRGB(255, 100, 0)),
            })
            timerGrad.Rotation = 45
            timerGrad.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0),
                NumberSequenceKeypoint.new(0.5, 0),
                NumberSequenceKeypoint.new(1, 0),
            })
            
            -- Animate the gradient rotation
            task.spawn(function()
                while timerLbl and timerLbl.Parent and timerLbl.Visible do
                    local grad = timerLbl:FindFirstChild("TimerGradient")
                    if grad then
                        TweenService:Create(grad, TweenInfo.new(2, Enum.EasingStyle.Linear), {Rotation = grad.Rotation + 180}):Play()
                        task.wait(2)
                    else
                        break
                    end
                end
            end)
        end
        
        -- Create speed label if it doesn't exist
        if not speedLbl and bb then
            speedLbl = Instance.new("TextLabel", bb)
            speedLbl.Name = "SpeedBillLbl"
            speedLbl.Size = UDim2.new(1, 0, 0.5, 0)
            speedLbl.Position = UDim2.new(0, 0, 0.5, 0)
            speedLbl.BackgroundTransparency = 1
            speedLbl.Text = "SPEED: 0.0"
            speedLbl.TextColor3 = THEME.LIGHT_BLUE
            speedLbl.FontFace = Font.new("rbxasset://fonts/families/Ubuntu.json", Enum.FontWeight.Bold, Enum.FontStyle.Italic)
            speedLbl.TextSize = 20
            speedLbl.TextScaled = true
            speedLbl.TextStrokeTransparency = 0.1
            speedLbl.TextStrokeColor3 = Color3.new(0, 0, 0)
            speedLbl.ZIndex = 10
            speedLbl.Visible = true
        end
        
        if not timerLbl then
            ragTimerActive = false
            return
        end
        
        local countdown = 3
        timerLbl.Visible = true
        
        -- Hide speed meter during ragdoll
        if speedLbl then
            speedLbl.Visible = false
        end
        
        while countdown > 0 do
            timerLbl.Text = tostring(countdown)
            -- Let the gradient handle the color
            task.wait(1)
            countdown = countdown - 1
        end
        
        timerLbl.Text = "GO"
        -- Let the gradient handle the color
        
        -- Wait until player is no longer ragdolled
        repeat 
            task.wait(0.1) 
        until (function()
            local c = LP.Character
            local hum = c and c:FindFirstChildOfClass("Humanoid")
            if not hum then return true end
            local st = hum:GetState()
            return st ~= Enum.HumanoidStateType.Physics 
                and st ~= Enum.HumanoidStateType.Ragdoll 
                and st ~= Enum.HumanoidStateType.FallingDown
                and hum.PlatformStand ~= true
        end)()
        
        timerLbl.Visible = false
        timerLbl.Text = ""
        
        -- Show speed meter again
        if speedLbl then
            speedLbl.Visible = true
        end
        
        ragTimerActive = false
    end)
end

